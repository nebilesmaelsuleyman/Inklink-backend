            "description": ""
          }
        },
        "summary": "Check moderation service connectivity from backend",
        "tags": [
          "moderation"
        ]
      }
    }
  },
  "info": {
    "title": "Ink Link Backend API",
    "description": "Authentication + Editor (Works, Chapters, Yjs collaboration persistence) endpoints",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "auth_token"
      },
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateWorkDto": {
        "type": "object",
        "properties": {
          "authorId": {
            "type": "string",
            "description": "Deprecated: ignored, author is derived from authenticated user"
          },
          "title": {
            "type": "string",
            "example": "My First Book"
          },
          "summary": {
            "type": "string",
            "example": "A short summary for the editor card."
          },
          "coverImage": {
            "type": "string",
            "example": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAA..."
          },
          "tags": {
            "example": [
              "fantasy",
              "adventure"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "title"
        ]
      },
      "UpdateWorkDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "My First Book (Updated)"
          },
          "summary": {
            "type": "string",
            "example": "Updated summary text."
          },
          "coverImage": {
            "type": "string",
            "example": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAA..."
          },
          "tags": {
            "example": [
              "romance",
              "drama"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "pending_moderation",
              "needs_admin_review",
              "approved",
              "rejected",
              "published"
            ],
            "example": "draft"
          }
        }
      },
      "CreateChapterDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Chapter 1"
          },
          "contentText": {
            "type": "string",
            "example": "Initial chapter content as plain text."
          },
          "orderIndex": {
            "type": "number",
            "example": 0
          }
        },
        "required": [
          "title"
        ]
      },
      "UpdateChapterDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Chapter 1 (Edited)"
          },
          "contentText": {
            "type": "string",
            "example": "Edited plain text content for this chapter."
          }
        }
      },
      "ReorderChaptersDto": {
        "type": "object",
        "properties": {
          "chapterIds": {
            "example": [
              "67f08df9b9e3adf31f5f4701",
              "67f08df9b9e3adf31f5f4702"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "orders": {
            "type": "array",
            "example": [
              {
                "id": "67f08df9b9e3adf31f5f4701",
                "orderIndex": 0
              },
              {
                "id": "67f08df9b9e3adf31f5f4702",
                "orderIndex": 1
              }
            ]
          }
        }
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "check"
          },
          "password": {
            "type": "string",
            "example": "12345678"
          },
          "email": {
            "type": "string",
            "example": "check@gmail.com"
          },
          "role": {
            "type": "string",
            "enum": [
              "user",
              "admin"
            ],
            "example": "user"
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "AuthUserDto": {
        "type": "object",
        "properties": {
          "sub": {
            "type": "string",
            "example": "67f08df9b9e3adf31f5f4701"
          },
          "username": {
            "type": "string",
            "example": "check"
          },
          "role": {
            "type": "string",
            "enum": [
              "user",
              "admin"
            ],
            "example": "user"
          }
        },
        "required": [
          "sub",
          "username",
          "role"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Login successful"
          },
          "user": {
            "$ref": "#/components/schemas/AuthUserDto"
          }
        },
        "required": [
          "message",
          "user"
        ]
      },
      "CreateAuthDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "check"
          },
          "password": {
            "type": "string",
            "example": "12345678"
          }
        },
        "required": [
          "username",
          "password"
        ]
      }
    }
  }
}