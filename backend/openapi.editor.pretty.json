    "/yjs/docs/{docId}/updates": {
      "post": {
        "operationId": "YjsController_appendUpdate",
        "parameters": [
          {
            "name": "docId",
            "required": true,
            "in": "path",
            "description": "Yjs document id or chapter id",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "update"
                ],
                "properties": {
                  "update": {
                    "type": "string",
                    "description": "base64-encoded Yjs update"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "auth_token": []
          }
        ],
        "summary": "Append Yjs binary update (base64)",
        "tags": [
          "editor-yjs"
        ]
      }
    },
    "/yjs/docs/{docId}/state": {
      "get": {
        "operationId": "YjsController_getState",
